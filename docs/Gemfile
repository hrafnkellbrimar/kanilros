source "https://rubygems.org"

# Use latest Jekyll with Ruby 4.x support
# This is compatible with modern Ruby versions
gem "jekyll", "~> 4.3"

# GitHub Pages optional (for feature parity, but not required)
# Fallback to direct dependencies for better Ruby 4.x support
# gem "github-pages"

# Minima theme
gem "minima"

# Jekyll plugins
group :jekyll_plugins do
  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-remote-theme"
end

# Development dependencies
group :development do
  gem "webrick", "~> 1.8"  # Required for Jekyll 4.x with Ruby 3.0+
end

# Windows and JRuby timezone data
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

# Windows filesystem watcher optimization
gem "wdm", "~> 0.1.1", platforms: [:mingw, :x64_mingw, :mswin]

# JRuby HTTP parser support
gem "http_parser.rb", "~> 0.6.0", platforms: [:jruby]
