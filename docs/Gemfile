source "https://rubygems.org"

# GitHub Pages with Ruby 2.7+ support
# This version is optimized for GitHub Pages CI/CD environment
# For local development with Ruby 4.x, use: make serve-docker
gem "github-pages", "~> 228", group: :jekyll_plugins

# Minima theme for Jekyll
gem "minima", "~> 2.5.1"

# Jekyll plugins for enhanced functionality
group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.12"
end

# Windows and JRuby timezone data
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", ">= 1", "< 3"
  gem "tzinfo-data"
end

# Windows filesystem watcher optimization
gem "wdm", "~> 0.1.1", platforms: [:mingw, :x64_mingw, :mswin]

# JRuby HTTP parser support
gem "http_parser.rb", "~> 0.6.0", platforms: [:jruby]

# NOTE: This Gemfile is optimized for Ruby 2.7 (used by GitHub Pages CI/CD)
# If you're using Ruby 4.x locally, use Docker: docker run --rm -it -v "$(pwd):/site" jekyll/jekyll:latest bundle install
